# Safety: connected execution is demo-only. Setting this to true aborts startup.
ENABLE_LIVE_TRADING=false
TRADING_MODE=demo_live

# MetaTrader 5 terminal credentials.
# Leave empty to use the already opened MT5 terminal session.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Optional free-plan APIs. The bot falls back gracefully when missing.
ALPHA_VANTAGE_API_KEY=
MARKETAUX_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
NEWSAPI_API_KEY=

# Optional runtime overrides.
LOG_LEVEL=INFO
DATABASE_PATH=data/trading_bot.sqlite
